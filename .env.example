# Backend base URL (no trailing slash).
VITE_API_BASE=http://localhost:3000

# Google OAuth *Client ID* only (ends in .apps.googleusercontent.com).
# NEVER put the client secret in the frontend — it ships to the browser.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Public website URL (no trailing slash). Used to build shareable /view links.
# REQUIRED for the Android APK — inside the app window.location.origin is
# "https://localhost", so without this, share links come out broken.
VITE_PUBLIC_WEB_BASE=https://your-site.vercel.app
